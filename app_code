# =========================================================
# Helpers
# =========================================================
def parse_datetime_columns(df: pd.DataFrame) -> pd.DataFrame:
    out = df.copy()
    for col in ["admit_datetime", "discharge_datetime"]:
        if col in out.columns:
            out[col] = pd.to_datetime(out[col], errors="coerce")
    return out


def validate_required_columns(df: pd.DataFrame, required_cols: list[str]) -> tuple[bool, list[str]]:
    missing = [c for c in required_cols if c not in df.columns]
    return len(missing) == 0, missing


def coerce_numeric(df: pd.DataFrame, numeric_cols: list[str]) -> pd.DataFrame:
    out = df.copy()
    for col in numeric_cols:
        if col in out.columns:
            out[col] = pd.to_numeric(out[col], errors="coerce")
    return out


def build_benchmark_from_uploaded_data(df: pd.DataFrame) -> pd.DataFrame:
    benchmark = (
        df.dropna(subset=["drg_code"])
        .groupby(["drg_type", "drg_code", "drg_desc", "drg_severity"], dropna=False)
        .agg(
            n_cases=("encounter_id", "count"),
            expected_los_days=("los_days", "median"),
            benchmark_los_mean=("los_days", "mean"),
            benchmark_los_p75=("los_days", lambda x: x.quantile(0.75)),
        )
        .reset_index()
    )
    benchmark["expected_los_days"] = pd.to_numeric(benchmark["expected_los_days"], errors="coerce").round(3)
    benchmark["benchmark_los_mean"] = pd.to_numeric(benchmark["benchmark_los_mean"], errors="coerce").round(3)
    benchmark["benchmark_los_p75"] = pd.to_numeric(benchmark["benchmark_los_p75"], errors="coerce").round(3)
    return benchmark


def merge_benchmark(encounters: pd.DataFrame, benchmark: pd.DataFrame) -> pd.DataFrame:
    merge_cols = ["drg_type", "drg_code", "drg_desc", "drg_severity"]
    merged = encounters.copy()
    bench = benchmark.copy()

    keep_cols = [c for c in BENCHMARK_COLUMNS if c in bench.columns]
    if "expected_los_days" not in keep_cols:
        raise ValueError("Benchmark file must contain expected_los_days.")

    bench = bench[keep_cols].drop_duplicates()
    bench["expected_los_days"] = pd.to_numeric(bench["expected_los_days"], errors="coerce")

    # Drop benchmark-derived columns if they already exist in the uploaded encounter file
    for col in ["expected_los_days", "los_variance_days", "los_oe_index", "excess_los_flag"]:
        if col in merged.columns:
            merged = merged.drop(columns=col)

    merged = merged.merge(bench, on=merge_cols, how="left")

    merged["los_variance_days"] = (
        pd.to_numeric(merged["los_days"], errors="coerce")
        - pd.to_numeric(merged["expected_los_days"], errors="coerce")
    ).round(3)

    merged["los_oe_index"] = np.where(
        merged["expected_los_days"].notna() & (merged["expected_los_days"] > 0),
        (
            pd.to_numeric(merged["los_days"], errors="coerce")
            / pd.to_numeric(merged["expected_los_days"], errors="coerce")
        ).round(3),
        np.nan,
    )
    return merged


def build_validation_summary(df: pd.DataFrame) -> pd.DataFrame:
    rows = []
    for col in REQUIRED_COLUMNS:
        rows.append(
            {
                "column_name": col,
                "present": col in df.columns,
                "missing_values": int(df[col].isna().sum()) if col in df.columns else None,
            }
        )
    return pd.DataFrame(rows)


def to_csv_download(df: pd.DataFrame) -> bytes:
    return df.to_csv(index=False).encode("utf-8")


def format_metric(value, is_pct=False):
    if pd.isna(value):
        return "NA"
    if is_pct:
        return f"{value:.1%}"
    if isinstance(value, (int, np.integer)):
        return f"{value:,}"
    return f"{value:,.2f}"


