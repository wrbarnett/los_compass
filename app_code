# Header
# =========================================================
st.title("LOS Compass")
st.caption("Turn LOS insights into action.")


# =========================================================
# Sidebar uploads
# =========================================================
with st.sidebar:
    st.header("Upload files")
    encounter_file = st.file_uploader(
        "1) Encounter dataset (required)",
